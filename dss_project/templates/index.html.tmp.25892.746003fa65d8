<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Stress Doctor - DSS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
  <script>
    tailwind.config = {
      safelist: [
        "bg-emerald-200",
        "text-emerald-900",
        "bg-amber-200",
        "text-amber-900",
        "bg-orange-200",
        "text-orange-900",
        "bg-red-200",
        "text-red-900",
        "bg-amber-100",
        "opacity-60",
        "cursor-not-allowed",
      ],
      theme: {
        extend: {
          colors: {
            ink: "#0f172a",
            cream: "#f9f5ef",
            sun: "#facc15",
          },
          fontFamily: {
            sans: ["Space Grotesk", "ui-sans-serif", "system-ui"],
            display: ["Bebas Neue", "sans-serif"],
          },
        },
      },
    };
  </script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/viz.js@2.1.2/viz.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/viz.js@2.1.2/full.render.js" defer></script>
  <script src="{{ url_for('static', filename='js/script.js') }}" defer></script>
</head>
<body class="min-h-screen bg-cream font-sans text-ink">
  <div class="mx-auto w-full max-w-6xl px-4 pb-20 pt-10 lg:px-8">
    <header class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between reveal" reveal data-animate>
      <div class="flex items-center gap-3">
        <!-- <div class="flex items-center gap-2 rounded-full border-2 border-ink bg-white px-3 py-1 text-xs font-bold uppercase tracking-widest">
          <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
          Student Stress Doctor
        </div>
        <span class="rounded-full border-2 border-ink bg-sun px-2 py-1 text-xs font-bold uppercase">Live Demo</span> -->
      </div>
      <nav class="flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-700">
        <a href="#formTitle" class="rounded-full border-2 border-ink bg-white px-3 py-2 transition hover:-translate-y-0.5">Input</a>
        <a href="#results" class="rounded-full border-2 border-ink bg-white px-3 py-2 transition hover:-translate-y-0.5">Hasil</a>
        <a href="#analysisTitle" class="rounded-full border-2 border-ink bg-white px-3 py-2 transition hover:-translate-y-0.5">Decision Tree</a>
        <a href="#datasetTitle" class="rounded-full border-2 border-ink bg-white px-3 py-2 transition hover:-translate-y-0.5">Dataset</a>
      </nav>
    </header>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1.1fr_0.9fr] reveal" reveal data-animate>
      <div class="space-y-6">
        <!-- <div class="flex flex-wrap items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-600">
          <span class="rounded-full border-2 border-ink bg-white px-3 py-1">Decision Support</span>
          <span class="rounded-full border-2 border-ink bg-white px-3 py-1">Real-time Insight</span>
        </div> -->
        <h1 class="leading-none space-y-1">
          <div class="font-display text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-ink">
            LIHAT TINGKAT STRES
          </div>
          <div class="font-display text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight">
            MAHASISWA ANDA
            <span class="text-red-600"> TERTEKAN</span>.
          </div>
          <div class="font-display text-3xl sm:text-4xl lg:text-5xl font-black tracking-tight">
            <span class="text-slate-400">DALAM</span>
            <span class="inline-flex items-center justify-center bg-ink px-3 py-1 text-sun font-display text-3xl sm:text-4xl lg:text-5xl min-w-[100px]">30</span>
            <span class="text-slate-400">DETIK.</span>
          </div>
        </h1>
        <p class="max-w-xl text-base text-slate-700 sm:text-lg">
          Isi 14 indikator psikologis, akademik, fisik, dan sosial. Sistem akan menampilkan hasil prediksi, jalur keputusan, serta rekomendasi tindakan.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="#formTitle" class="rounded-full border-2 border-ink bg-sun px-6 py-3 text-xs font-bold uppercase tracking-widest shadow-brutal transition hover:-translate-y-0.5">
            Mulai Prediksi
          </a>
          <button id="openDatasetModal" class="rounded-full border-2 border-ink bg-white px-6 py-3 text-xs font-bold uppercase tracking-widest shadow-brutal transition hover:-translate-y-0.5">
            Preview Dataset
          </button>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          <div class="rounded-2xl border-2 border-ink bg-white p-4 shadow-brutal-sm card-animate" reveal data-animate>
            <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Indikator</p>
            <p class="font-display text-3xl">14</p>
            <p class="text-xs text-slate-600">Input lengkap untuk akurasi.</p>
          </div>
          <div class="rounded-2xl border-2 border-ink bg-white p-4 shadow-brutal-sm card-animate" reveal data-animate>
            <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Target</p>
            <p class="font-display text-3xl">4</p>
            <p class="text-xs text-slate-600">Stress, anxiety, final state, intervensi.</p>
          </div>
          <div class="rounded-2xl border-2 border-ink bg-white p-4 shadow-brutal-sm card-animate" reveal data-animate>
            <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Model</p>
            <p class="font-display text-3xl">Tree</p>
            <p class="text-xs text-slate-600">Transparan & mudah dijelaskan.</p>
          </div>
        </div>
      </div>

      <div class="space-y-6" style="margin-bottom: 60px;">
        <!-- Header -->
        <div class="flex items-center gap-3">
          <div class="flex gap-1.5">
            <span class="w-3 h-3 rounded-full bg-red-500"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
            <span class="w-3 h-3 rounded-full bg-green-500"></span>
          </div>
          <span class="inline-block rounded px-4 py-2 text-xs font-bold uppercase tracking-widest text-white bg-purple-600 border-2 border-ink">DSS MEMORY ROOT</span>
        </div>

        <!-- Windows Container -->
        <div class="grid gap-6 lg:grid-cols-3">
          <!-- diagnose.stream Window -->
          <div class="lg:col-span-2">
            <div class="rounded-2xl border-4 border-ink bg-white p-6 shadow-lg" style="box-shadow: 12px 12px 0 rgba(0,0,0,0.15);">
              <div class="flex items-center gap-3 mb-5 pb-4 border-b-2 border-slate-200">
                <div class="flex gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-500"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-green-500"></span>
                </div>
                <span class="text-xs font-bold text-slate-700">diagnose.stream</span>
              </div>

              <div class="bg-purple-50 rounded-lg p-3 mb-5 border border-purple-200">
                <p class="text-xs text-slate-600 font-mono">sessionId 8f4a2c · streaming</p>
              </div>

              <ol class="space-y-2.5 text-sm">
                <li class="flex items-center justify-between">
                  <span class="text-slate-700 font-medium"><span class="text-slate-400 font-mono text-xs">01</span> score.capture</span>
                  <span class="text-emerald-600 text-xs font-bold tracking-wider">VERIFIED</span>
                </li>
                <li class="flex items-center justify-between">
                  <span class="text-slate-700 font-medium"><span class="text-slate-400 font-mono text-xs">02</span> stress.classify</span>
                  <span class="text-blue-600 text-xs font-bold tracking-wider">COMPUTED</span>
                </li>
                <li class="flex items-center justify-between">
                  <span class="text-slate-700 font-medium"><span class="text-slate-400 font-mono text-xs">03</span> path.explain</span>
                  <span class="text-amber-600 text-xs font-bold tracking-wider">ESTIMATED</span>
                </li>
                <li class="flex items-center justify-between">
                  <span class="text-slate-700 font-medium"><span class="text-slate-400 font-mono text-xs">04</span> action.recommend</span>
                  <span class="text-purple-600 text-xs font-bold tracking-wider">LABELED</span>
                </li>
                <li class="flex items-center justify-between">
                  <span class="text-slate-700 font-medium"><span class="text-slate-400 font-mono text-xs">05</span> intervention.track</span>
                  <span class="text-blue-600 text-xs font-bold tracking-wider">COMPUTED</span>
                </li>
              </ol>
            </div>
          </div>

          <!-- backend.status Window -->
          <div>
            <div class="rounded-2xl border-4 border-ink bg-white p-6 shadow-lg" style="box-shadow: 12px 12px 0 rgba(0,0,0,0.15);">
              <div class="flex items-center gap-3 mb-5 pb-4 border-b-2 border-slate-200">
                <div class="flex gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-500"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-green-500"></span>
                </div>
                <span class="text-xs font-bold text-slate-700">backend.status</span>
              </div>

              <div class="bg-emerald-50 rounded-lg p-4 border border-emerald-200">
                <p class="text-xs text-slate-600 font-mono mb-3">flask.localhost:5000</p>
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                  <span class="text-xs font-bold text-emerald-700">RUNNING</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <main class="mt-12 grid gap-8 lg:grid-cols-[1.1fr_0.9fr]" reveal data-animate>
      <section class="rounded-3xl border-2 border-ink bg-white p-6 shadow-brutal card-animate" aria-labelledby="formTitle">
        <div class="space-y-2">
          <h2 id="formTitle" class="font-display text-3xl">Form Konsultasi</h2>
          <p class="text-sm text-slate-600">Isi data berikut untuk memulai proses prediksi.</p>
        </div>

        <form id="predictionForm" class="mt-6 space-y-6" novalidate>
          <div class="rounded-2xl border-2 border-ink bg-white p-5 card-animate" reveal data-animate>
            <div class="flex items-center justify-between gap-2">
              <h3 class="font-display text-xl">Metrik Psikologis</h3>
              <span class="text-xs font-bold uppercase tracking-widest text-slate-500">4 indikator</span>
            </div>
            <div class="mt-4 grid gap-4 md:grid-cols-2">
              <label class="space-y-2">
                <span class="text-sm font-semibold">Skor Stres</span>
                <div class="flex items-center justify-between text-xs text-slate-600">
                  <span>0 - 100</span>
                  <span class="rounded-full border-2 border-ink bg-sun px-3 py-1 font-bold" data-for="stress_score">50</span>
                </div>
                <input type="range" id="stress_score" name="stress_score" min="0" max="100" value="50" class="w-full accent-emerald-600" required>
                <p class="text-xs text-slate-500">Semakin tinggi skor, semakin besar tekanan.</p>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold">Skor Kecemasan</span>
                <div class="flex items-center justify-between text-xs text-slate-600">
                  <span>0 - 100</span>
                  <span class="rounded-full border-2 border-ink bg-sun px-3 py-1 font-bold" data-for="anxiety_score">50</span>
                </div>
                <input type="range" id="anxiety_score" name="anxiety_score" min="0" max="100" value="50" class="w-full accent-emerald-600" required>
                <p class="text-xs text-slate-500">Menggambarkan kecemasan harian.</p>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold">Skor Reward</span>
                <div class="flex items-center justify-between text-xs text-slate-600">
                  <span>0 - 100</span>
                  <span class="rounded-full border-2 border-ink bg-sun px-3 py-1 font-bold" data-for="reward_score">50</span>
                </div>
                <input type="range" id="reward_score" name="reward_score" min="0" max="100" value="50" class="w-full accent-emerald-600" required>
                <p class="text-xs text-slate-500">Seberapa besar reward yang dirasakan.</p>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold">Kondisi Mood</span>
                <select id="mood_state" name="mood_state" class="w-full rounded-xl border-2 border-ink bg-white px-3 py-2 text-sm" required>
                  <option value="Neutral" selected>Netral</option>
                  <option value="Happy">Senang</option>
                  <option value="Sad">Sedih</option>
                  <option value="Anxious">Cemas</option>
                  <option value="Excited">Bersemangat</option>
                </select>
                <p class="text-xs text-slate-500">Pilih mood dominan saat ini.</p>
              </label>
            </div>
          </div>

          <div class="rounded-2xl border-2 border-ink bg-white p-5 card-animate" reveal data-animate>
            <div class="flex items-center justify-between gap-2">
              <h3 class="font-display text-xl">Indikator Akademik</h3>
              <span class="text-xs font-bold uppercase tracking-widest text-slate-500">4 indikator</span>
            </div>
            <div class="mt-4 grid gap-4 md:grid-cols-2">
              <label class="space-y-2">
                <span class="text-sm font-semibold">Tekanan Ujian</span>
                <input type="number" id="exam_pressure" name="exam_pressure" min="0" max="10" value="5" class="w-full rounded-xl border-2 border-ink bg-white px-3 py-2 text-sm" required>
                <p class="text-xs text-slate-500">Skala 0-10 untuk beban ujian.</p>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold">Beban Tugas</span>
                <input type="number" id="assignment_load" name="assignment_load" min="0" max="10" value="5" class="w-full rounded-xl border-2 border-ink bg-white px-3 py-2 text-sm" required>
                <p class="text-xs text-slate-500">Skala 0-10 untuk intensitas tugas.</p>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold">Jam Belajar</span>
                <input type="number" id="study_hours" name="study_hours" min="0" max="24" step="0.5" value="4" class="w-full rounded-xl border-2 border-ink bg-white px-3 py-2 text-sm" required>
                <p class="text-xs text-slate-500">Total jam belajar per hari.</p>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold">Kehadiran</span>
                <div class="flex items-center justify-between text-xs text-slate-600">
                  <span>0 - 100</span>
                  <span class="rounded-full border-2 border-ink bg-sun px-3 py-1 font-bold" data-for="attendance">80</span>
                </div>
                <input type="range" id="attendance" name="attendance" min="0" max="100" value="80" class="w-full accent-emerald-600" required>
                <p class="text-xs text-slate-500">Persentase kehadiran kuliah.</p>
              </label>
            </div>
          </div>

          <div class="rounded-2xl border-2 border-ink bg-white p-5 card-animate" reveal data-animate>
            <div class="flex items-center justify-between gap-2">
              <h3 class="font-display text-xl">Kesehatan Fisik</h3>
              <span class="text-xs font-bold uppercase tracking-widest text-slate-500">4 indikator</span>
            </div>
            <div class="mt-4 grid gap-4 md:grid-cols-2">
              <label class="space-y-2">
                <span class="text-sm font-semibold">Jam Tidur</span>
                <input type="number" id="sleep_hours" name="sleep_hours" min="0" max="24" step="0.5" value="7" class="w-full rounded-xl border-2 border-ink bg-white px-3 py-2 text-sm" required>
                <p class="text-xs text-slate-500">Total jam tidur per hari.</p>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold">Detak Jantung</span>
                <input type="number" id="heart_rate" name="heart_rate" min="40" max="200" value="80" class="w-full rounded-xl border-2 border-ink bg-white px-3 py-2 text-sm" required>
                <p class="text-xs text-slate-500">Detak jantung rata-rata (bpm).</p>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold">Aktivitas Fisik</span>
                <input type="number" id="physical_activity" name="physical_activity" min="0" max="10" value="5" class="w-full rounded-xl border-2 border-ink bg-white px-3 py-2 text-sm" required>
                <p class="text-xs text-slate-500">Skala 0-10 untuk aktivitas fisik.</p>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold">Waktu Layar</span>
                <input type="number" id="screen_time" name="screen_time" min="0" max="24" step="0.5" value="6" class="w-full rounded-xl border-2 border-ink bg-white px-3 py-2 text-sm" required>
                <p class="text-xs text-slate-500">Jam screen time per hari.</p>
              </label>
            </div>
          </div>

          <div class="rounded-2xl border-2 border-ink bg-white p-5 card-animate" reveal data-animate>
            <div class="flex items-center justify-between gap-2">
              <h3 class="font-display text-xl">Sosial & Perilaku</h3>
              <span class="text-xs font-bold uppercase tracking-widest text-slate-500">3 indikator</span>
            </div>
            <div class="mt-4 grid gap-4 md:grid-cols-2">
              <label class="space-y-2">
                <span class="text-sm font-semibold">Dukungan Sosial</span>
                <input type="number" id="social_support" name="social_support" min="0" max="10" value="5" class="w-full rounded-xl border-2 border-ink bg-white px-3 py-2 text-sm" required>
                <p class="text-xs text-slate-500">Skala 0-10 untuk dukungan sosial.</p>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold">Ekspresi Wajah</span>
                <select id="facial_emotion" name="facial_emotion" class="w-full rounded-xl border-2 border-ink bg-white px-3 py-2 text-sm" required>
                  <option value="Neutral" selected>Netral</option>
                  <option value="Happy">Senang</option>
                  <option value="Sad">Sedih</option>
                  <option value="Angry">Marah</option>
                  <option value="Surprised">Terkejut</option>
                </select>
                <p class="text-xs text-slate-500">Ekspresi dominan saat ini.</p>
              </label>
              <label class="space-y-2">
                <span class="text-sm font-semibold">Respons Intervensi</span>
                <select id="intervention_response" name="intervention_response" class="w-full rounded-xl border-2 border-ink bg-white px-3 py-2 text-sm" required>
                  <option value="Positive" selected>Positif</option>
                  <option value="Neutral">Netral</option>
                  <option value="Negative">Negatif</option>
                </select>
                <p class="text-xs text-slate-500">Respons terhadap intervensi sebelumnya.</p>
              </label>
            </div>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <button type="button" id="clearForm" class="rounded-full border-2 border-ink bg-white px-6 py-3 text-xs font-bold uppercase tracking-widest shadow-brutal-sm transition hover:-translate-y-0.5">
              Bersihkan Form
            </button>
            <button type="submit" id="predictButton" class="flex-1 rounded-full border-2 border-ink bg-ink px-6 py-3 text-xs font-bold uppercase tracking-widest text-ink shadow-brutal transition hover:-translate-y-0.5">
              Prediksi Tingkat Stres
            </button>
          </div>
        </form>

        <div id="loading" class="mt-4 flex items-center gap-2 text-sm text-slate-600" hidden>
          <span class="h-4 w-4 animate-spin rounded-full border-2 border-ink border-t-emerald-500"></span>
          <span>Menjalankan prediksi...</span>
        </div>

        <div id="errorMessage" class="mt-4 rounded-xl border-2 border-red-500 bg-red-50 p-3 text-sm text-red-700" role="alert" hidden></div>
      </section>

      <aside class="space-y-6" reveal data-animate>
        <div id="results" class="rounded-3xl border-2 border-ink bg-white p-6 shadow-brutal card-animate" aria-live="polite" hidden>
          <div class="space-y-4">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Ringkasan</p>
              <h2 class="font-display text-3xl">Hasil Prediksi</h2>
            </div>

            <div class="flex flex-wrap gap-2">
              <span id="stressBadge" class="inline-flex items-center gap-2 rounded-full border-2 border-ink px-3 py-1 text-xs font-bold uppercase tracking-wide">Stres: --</span>
              <span id="anxietyBadge" class="inline-flex items-center gap-2 rounded-full border-2 border-ink px-3 py-1 text-xs font-bold uppercase tracking-wide">Kecemasan: --</span>
            </div>

            <div class="rounded-2xl border-2 border-ink bg-slate-50 p-4">
              <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Status Akhir</p>
              <p id="finalState" class="mt-1 text-lg font-semibold">--</p>
            </div>

            <div class="rounded-2xl border-2 border-ink bg-emerald-50 p-4">
              <p class="text-xs font-bold uppercase tracking-widest text-emerald-700">Intervensi Disarankan</p>
              <p id="recommendation" class="mt-1 text-lg font-semibold text-emerald-900">--</p>
            </div>

            <div>
              <div class="flex items-center justify-between text-sm font-semibold text-slate-600">
                <span>Tingkat Keyakinan</span>
                <span id="confidenceValue">0%</span>
              </div>
              <div class="mt-2 h-2 w-full rounded-full border-2 border-ink bg-white">
                <div id="confidenceBar" class="h-2 w-0 rounded-full bg-gradient-to-r from-emerald-400 via-sun to-blue-500"></div>
              </div>
            </div>

            <div>
              <h3 class="font-display text-xl">Faktor Utama</h3>
              <ul id="keyFactors" class="mt-2 space-y-2"></ul>
            </div>

            <div>
              <h3 class="font-display text-xl">Rekomendasi Aksi</h3>
              <ul id="recommendationList" class="mt-2 space-y-2"></ul>
            </div>

            <div class="rounded-2xl border-2 border-ink bg-white p-4 text-sm text-slate-600">
              <p id="explanationText">--</p>
            </div>
          </div>
        </div>

        <div class="rounded-3xl border-2 border-ink bg-white p-6 shadow-brutal card-animate" reveal data-animate>
          <h3 class="font-display text-2xl text-ink">Panduan Cepat</h3>
          <ul class="mt-3 space-y-2 text-sm text-ink">
            <li>Isi data sesuai kondisi terbaru kamu.</li>
            <li>Klik Prediksi untuk melihat hasil.</li>
            <li>Bandingkan jalur decision tree pada tab analisis.</li>
          </ul>
        </div>
      </aside>
    </main>

    <section class="mt-14 rounded-3xl border-2 border-ink bg-white p-6 shadow-brutal section-animate" aria-labelledby="analysisTitle" reveal data-animate>
      <div class="space-y-6">
        <div class="flex flex-col gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Decision Tree</p>
            <h2 id="analysisTitle" class="font-display text-4xl lg:text-5xl font-black">Visualisasi Pohon Keputusan</h2>
            <p class="mt-3 text-sm text-slate-600">Pilih target untuk melihat tree dan jalur keputusan dari input kamu.</p>
          </div>
          <div class="flex flex-wrap gap-2" role="tablist" aria-label="Pilih target tree">
            <button type="button" class="tree-tab rounded-full border-2 border-ink bg-sun px-6 py-3 text-xs font-bold uppercase tracking-widest transition hover:-translate-y-0.5" data-target="stress_level" aria-pressed="true">Tingkat Stres</button>
            <button type="button" class="tree-tab rounded-full border-2 border-ink bg-white px-6 py-3 text-xs font-bold uppercase tracking-widest transition hover:-translate-y-0.5" data-target="anxiety_level" aria-pressed="false">Kecemasan</button>
            <button type="button" class="tree-tab rounded-full border-2 border-ink bg-white px-6 py-3 text-xs font-bold uppercase tracking-widest transition hover:-translate-y-0.5" data-target="final_state" aria-pressed="false">Status Akhir</button>
            <button type="button" class="tree-tab rounded-full border-2 border-ink bg-white px-6 py-3 text-xs font-bold uppercase tracking-widest transition hover:-translate-y-0.5" data-target="recommended_intervention" aria-pressed="false">Intervensi</button>
          </div>
        </div>

        <article class="tree-card flex flex-col gap-4 rounded-2xl border-2 border-ink bg-slate-50 p-6" data-target="stress_level" role="tabpanel">
          <div class="flex items-center justify-between gap-2">
            <h3 class="font-display text-2xl font-black">Tree Tingkat Stres</h3>
            <span class="text-xs font-bold uppercase tracking-widest text-slate-500 bg-white px-3 py-1 rounded-full border border-slate-300" id="treeStatus-stress_level">Memuat...</span>
          </div>
          <div class="bg-white rounded-xl border-2 border-ink p-6">
            <div id="tree-stress_level" class="tree-grid"></div>
          </div>
          <div class="bg-white rounded-xl border-2 border-ink p-4">
            <h4 class="font-display text-lg font-bold mb-3">Jalur Keputusan</h4>
            <ol class="space-y-2" id="path-stress_level"></ol>
          </div>
        </article>

        <article class="tree-card hidden flex-col gap-4 rounded-2xl border-2 border-ink bg-slate-50 p-6" data-target="anxiety_level" role="tabpanel">
          <div class="flex items-center justify-between gap-2">
            <h3 class="font-display text-2xl font-black">Tree Tingkat Kecemasan</h3>
            <span class="text-xs font-bold uppercase tracking-widest text-slate-500 bg-white px-3 py-1 rounded-full border border-slate-300" id="treeStatus-anxiety_level">Memuat...</span>
          </div>
          <div class="bg-white rounded-xl border-2 border-ink p-6">
            <div id="tree-anxiety_level" class="tree-grid"></div>
          </div>
          <div class="bg-white rounded-xl border-2 border-ink p-4">
            <h4 class="font-display text-lg font-bold mb-3">Jalur Keputusan</h4>
            <ol class="space-y-2" id="path-anxiety_level"></ol>
          </div>
        </article>

        <article class="tree-card hidden flex-col gap-4 rounded-2xl border-2 border-ink bg-slate-50 p-6" data-target="final_state" role="tabpanel">
          <div class="flex items-center justify-between gap-2">
            <h3 class="font-display text-2xl font-black">Tree Status Akhir</h3>
            <span class="text-xs font-bold uppercase tracking-widest text-slate-500 bg-white px-3 py-1 rounded-full border border-slate-300" id="treeStatus-final_state">Memuat...</span>
          </div>
          <div class="bg-white rounded-xl border-2 border-ink p-6">
            <div id="tree-final_state" class="tree-grid"></div>
          </div>
          <div class="bg-white rounded-xl border-2 border-ink p-4">
            <h4 class="font-display text-lg font-bold mb-3">Jalur Keputusan</h4>
            <ol class="space-y-2" id="path-final_state"></ol>
          </div>
        </article>

        <article class="tree-card hidden flex-col gap-4 rounded-2xl border-2 border-ink bg-slate-50 p-6" data-target="recommended_intervention" role="tabpanel">
          <div class="flex items-center justify-between gap-2">
            <h3 class="font-display text-2xl font-black">Tree Intervensi</h3>
            <span class="text-xs font-bold uppercase tracking-widest text-slate-500 bg-white px-3 py-1 rounded-full border border-slate-300" id="treeStatus-recommended_intervention">Memuat...</span>
          </div>
          <div class="bg-white rounded-xl border-2 border-ink p-6">
            <div id="tree-recommended_intervention" class="tree-grid"></div>
          </div>
          <div class="bg-white rounded-xl border-2 border-ink p-4">
            <h4 class="font-display text-lg font-bold mb-3">Jalur Keputusan</h4>
            <ol class="space-y-2" id="path-recommended_intervention"></ol>
          </div>
        </article>
      </div>
    </section>

    <section class="mt-14 rounded-3xl border-2 border-ink bg-white p-6 shadow-brutal section-animate" aria-labelledby="datasetTitle" reveal data-animate>
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Dataset</p>
          <h2 id="datasetTitle" class="font-display text-3xl">Preview Dataset</h2>
          <p class="mt-2 text-sm text-slate-600">Cek sampel data training dan validasi input.</p>
        </div>
        <button id="openDatasetModalSecondary" class="rounded-full border-2 border-ink bg-white px-6 py-3 text-xs font-bold uppercase tracking-widest shadow-brutal-sm transition hover:-translate-y-0.5">
          Buka Preview
        </button>
      </div>
      <p id="datasetSummary" class="mt-4 text-sm text-slate-600">Memuat preview dataset...</p>
    </section>
  </div>

  <div id="datasetModal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="datasetModalTitle">
    <div class="absolute inset-0 bg-slate-900/60" data-modal-overlay="true"></div>
    <div class="relative w-full max-w-4xl max-h-[85vh] flex flex-col rounded-3xl border-2 border-ink bg-white shadow-brutal">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between p-6 border-b-2 border-ink flex-shrink-0">
        <div>
          <h3 id="datasetModalTitle" class="font-display text-3xl">Preview Dataset</h3>
          <p class="text-sm text-slate-600">Sample data training untuk melihat pola input.</p>
        </div>
        <button id="closeDatasetModal" class="rounded-full border-2 border-ink bg-white px-4 py-2 text-xs font-bold uppercase tracking-widest shadow-brutal-sm transition hover:-translate-y-0.5">
          Tutup
        </button>
      </div>
      <div class="flex-1 overflow-y-auto hide-scrollbar p-6">
        <p class="text-sm text-slate-600 mb-4" id="datasetModalSummary">Memuat preview dataset...</p>
        <div class="overflow-x-auto rounded-2xl border-2 border-ink">
          <table class="min-w-full text-left text-sm" id="datasetTable">
            <thead class="bg-slate-100 text-xs font-bold uppercase tracking-widest text-slate-500">
              <tr></tr>
            </thead>
            <tbody class="divide-y divide-slate-200"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
